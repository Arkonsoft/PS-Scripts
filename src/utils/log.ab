pub fun log_info(msg: Text) {
    trust $ printf "\\033[1;36m[INFO]\\033[0m %s\n" "{msg}" $
}

pub fun log_success(msg: Text) {
    trust $ printf "\\033[1;32m[SUCCESS]\\033[0m %s\n" "{msg}" $
}

pub fun log_warning(msg: Text) {
    trust $ printf "\\033[1;33m[WARNING]\\033[0m %s\n" "{msg}" $
}

pub fun log_error(msg: Text) {
    trust $ printf "\\033[1;31m[ERROR]\\033[0m %s\n" "{msg}" >&2 $
}
